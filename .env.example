# Copy this file to .env and paste your real Discord webhook URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Concert presentation page. The watcher finds the "Reserver billet" link from here.
PRESENTATION_URL=https://www.arkeaarena.com/evenements/electric-callboy-en-concert-30-janvier-2027-billetterie-bordeaux

# Optional: override automatic discovery with a direct ticketing URL.
# WATCH_URL=https://billetterie.arkeaarena.com/fr/manifestation/electric-callboy-billet/idmanif/659872/idseance/4340678/codtypadh/PRM/numadh/01/codeconf/promo01

# Optional: override automatic API URL derivation.
# API_URL=https://billetterie.arkeaarena.com/api/grille-tarifaire/manifestation/idmanif/659872/seance/idseance/4340678/23992404?codLang=FR&codtypadh=PRM&codCoMod=WEB&codeconf=promo01&numadh=01

# Optional: override automatic reCAPTCHA site-key discovery.
# RECAPTCHA_SITE_KEY=6L...

# Optional: override browser identity headers.
# USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36
# SEC_CH_UA="\"Chromium\";v=\"148\", \"Google Chrome\";v=\"148\", \"Not/A)Brand\";v=\"99\""
# SEC_CH_UA_PLATFORM="\"Linux\""

# Be kind to the ticketing site. 180 seconds is the default.
POLL_SECONDS=180

# If anti-bot blocks the API, pause instead of retrying every poll.
BLOCK_COOLDOWN_MINUTES=180

# Optional: comma-separated category codes/names. Defaults to all three.
WATCH_CATEGORIES=01,02,FO

# Optional: set to 1 to send a Discord message when the watcher starts.
DISCORD_NOTIFY_ON_START=0

# Optional: set to 1 to log Discord messages without sending them.
DISCORD_DRY_RUN=0

# Optional: set to 1 to log bootstrap status and cookie presence.
DEBUG_BOOTSTRAP=0

# Optional: override where cookies/session state is stored.
SESSION_FILE=session.json

# Optional: set to 1 for smoke tests instead of running forever.
RUN_ONCE=0
